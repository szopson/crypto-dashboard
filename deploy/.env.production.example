# Trading Command Center - Production Environment Variables
# Copy this file to .env.production and fill in your values

# ===========================================
# EXCHANGE CONFIGURATION
# ===========================================
EXCHANGE_ID=bybit
EXCHANGE_SYMBOL=BTC/USDT:USDT
EXCHANGE_TIMEFRAME=1d

# API Keys (use testnet for safety, or real keys for production)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# Set to false for real trading
BYBIT_TESTNET=false

# ===========================================
# TELEGRAM NOTIFICATIONS
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=your_channel_id
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ===========================================
# DATABASE
# ===========================================
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./data/trading.db

# PostgreSQL (optional, more robust for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_db

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Environment
ENVIRONMENT=production
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS (add your domain)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===========================================
# SECURITY
# ===========================================
# Secret key for session encryption (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# API rate limiting
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# AI & LLM CONFIGURATION
# ===========================================
# Anthropic Claude (primary)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (fallback for project analysis)
OPENAI_API_KEY=your_openai_api_key

# OpenRouter (alternative)
OPENROUTER_API_KEY=your_openrouter_api_key

# Perplexity (for project research)
PERPLEXITY_API_KEY=your_perplexity_api_key

# ===========================================
# GOOGLE OAUTH (Optional - future auth)
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# OPTIONAL: EXTERNAL APIS
# ===========================================
# Fear & Greed Index (free, no key needed)
# FEAR_GREED_API_URL=https://api.alternative.me/fng/

# ===========================================
# MONITORING (Optional)
# ===========================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===========================================
# BACKUP SETTINGS
# ===========================================
# Backup directory
BACKUP_DIR=/app/data/backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=30
