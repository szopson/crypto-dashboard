# ============================================================
# Trading Command Center — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
# ============================================================

# -----------------------------------------------------------
# Anthropic / Claude AI
# Required for LLM features (chat assistant, chart analysis,
# daily briefing, one-click AI analysis).
# -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------
# Database
# SQLite is used by default (better-sqlite3). Set a path for
# the database file. For PostgreSQL set DATABASE_URL instead.
# -----------------------------------------------------------
SQLITE_DB_PATH=./data/trading.db
# DATABASE_URL=postgresql://user:password@localhost:5432/trading

# -----------------------------------------------------------
# CCXT / Exchange Data
# Used by the OHLCV ingestion service. Provide API keys only
# if you need private endpoints (authenticated trading data).
# Public OHLCV data works without keys for most exchanges.
# -----------------------------------------------------------
CCXT_EXCHANGE=binance
# CCXT_API_KEY=
# CCXT_API_SECRET=

# -----------------------------------------------------------
# Internal API security
# Secret sent as X-Refresh-Secret header by n8n to /api/internal/refresh.
# If unset, the endpoint is unprotected (OK for local dev only).
# -----------------------------------------------------------
INTERNAL_REFRESH_SECRET=change-me-in-production

# -----------------------------------------------------------
# n8n Workflow Automation
# n8n is used for scheduled RADAR data refresh workflows.
# Point this at your local or cloud n8n instance.
# -----------------------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# -----------------------------------------------------------
# Next.js public runtime config
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# -----------------------------------------------------------
NEXT_PUBLIC_APP_ENV=development
