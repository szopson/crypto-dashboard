# Trading Command Center - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# App Settings
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Exchange Configuration (CCXT)
EXCHANGE_ID=bybit
DEFAULT_SYMBOL=BTC/USDT:USDT

# Data Fetching
OHLCV_LIMIT=300
REFRESH_INTERVAL_SECONDS=3600

# RADAR Thresholds
BBWP_LOW_THRESHOLD=20.0
BBWP_HIGH_THRESHOLD=80.0
FUNDING_RATE_THRESHOLD=0.01

# LLM (Claude API) - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (alternative LLM) - Get from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Perplexity (for web research) - Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google OAuth (optional, for future authentication)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Telegram Bot - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here
TELEGRAM_GROUP_ID=your_telegram_group_id_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
