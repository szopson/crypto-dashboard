# Trading Command Center - Production Environment

# ===================
# App Settings
# ===================
DEBUG=false
APP_NAME=Trading Command Center

# ===================
# Database
# ===================
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# ===================
# Exchange
# ===================
EXCHANGE_ID=bybit
DEFAULT_SYMBOL=BTC/USDT:USDT

# ===================
# API Keys
# ===================
ANTHROPIC_API_KEY=sk-ant-xxx
COINGECKO_API_KEY=
PERPLEXITY_API_KEY=
GITHUB_TOKEN=
DUNE_API_KEY=

# ===================
# Telegram
# ===================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===================
# Alerts & Scheduler
# ===================
ALERT_MONITOR_ENABLED=true
ALERT_CHECK_INTERVAL_SECONDS=300
SCHEDULER_ENABLED=true
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_HOUR=8
DAILY_BRIEFING_MINUTE=0
DAILY_BRIEFING_TIMEZONE=Europe/Warsaw

# ===================
# CORS
# ===================
CORS_ORIGINS=https://tcc.yourdomain.com
